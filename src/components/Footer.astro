---
import { BrandLogo } from './BrandLogo';
import { X, Send, ArrowUpRight } from 'lucide-react';

const currentYear = new Date().getFullYear();

const { role } = Astro.locals;
const isAdmin = role === 'admin';

const socialLinks = [
  { 
    name: 'X (Twitter)', 
    href: 'https://x.com/AysuhMishra', 
    icon: X 
  },
  { 
    name: 'Telegram', 
    href: 'https://t.me/+3NlArnuptl8yZGRl', 
    icon: Send 
  },
  { 
    name: 'LinkedIn', 
    href: 'https://www.linkedin.com/in/ayush-kumar-m-558b631b0', 
    icon: 'linkedin'
  },
];

const quickLinks = [
  { name: 'Home', href: '/' },
  { name: 'BMI Calculator', href: '/#calculator' },
  { name: 'BMR Calculator', href: '/bmr-calculator/' },
  { name: 'Calorie Calculator', href: '/calorie-calculator/' },
  { name: 'Water Intake Calculator', href: '/water-intake-calculator/' },
  { name: 'Ideal Weight Calculator', href: '/ideal-weight-calculator/' },
  { name: 'How it Works', href: '/#how-it-works' },
  { name: 'BMI Categories', href: '/#bmi-categories' },
  { name: 'FAQ', href: '/#faq' },
];

const legalLinks = [
  { name: 'WHO Guidelines', href: 'https://www.who.int/data/gho/data/themes/topics/topic-details/GHO/body-mass-index', external: true },
  { name: 'About Us', href: '/about' },
  { name: 'Contact Us', href: '/contact' },
  { name: 'Privacy Policy', href: '/privacy-policy' },
  { name: 'Terms of Use', href: '/terms-and-conditions' },
];
---

{!isAdmin && (
<footer class="bg-canvas border-t border-hairline pt-12 pb-12 lg:pt-16 lg:pb-16 relative z-10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-x-8 gap-y-12 lg:gap-16 mb-12 lg:mb-16">
      
      {/* LEFT SIDE: Brand & Social */}
      <div class="md:col-span-2 lg:col-span-5 space-y-6 min-w-0">
        <a href="/" class="inline-flex items-center gap-3 group">
          <BrandLogo className="w-10 h-10 transition-transform duration-500 group-hover:rotate-6 group-hover:scale-110" variant="ink" />
          <div class="flex flex-col">
            <span class="font-black text-xl tracking-tighter text-ink leading-tight">QuickBMI</span>
            <span class="text-[9px] font-mono font-bold text-status-healthy/90 uppercase tracking-widest">Real-time BMI Engine</span>
          </div>
        </a>
        <div class="space-y-6">
          <p class="text-mute text-sm leading-relaxed max-w-md font-medium">
            Professional BMI analysis platform for accurate body measurement insights. Empowering wellness through precision analytics.
          </p>
          <div class="flex flex-wrap gap-3">
            {socialLinks.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                class="relative w-10 h-10 flex items-center justify-center rounded-xl bg-canvas-soft border border-hairline text-mute hover:text-ink hover:border-hairline-strong transition-all duration-500 shadow-premium-sm hover:shadow-premium-md hover:-translate-y-1 active:scale-95 group"
                aria-label={social.name}
              >
                <span class="transition-transform duration-500 group-hover:scale-105 relative z-10 scale-90">
                  {social.name === 'LinkedIn' ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>
                    </svg>
                  ) : (
                    <social.icon className="w-5 h-5" />
                  )}
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* CENTER: Quick Links */}
      <div class="lg:col-span-4 space-y-6 min-w-0">
        <h4 class="text-[10px] font-mono font-bold text-mute uppercase tracking-[0.3em]">Quick Links</h4>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
          {quickLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class="text-sm font-bold text-ink/60 hover:text-ink transition-colors duration-200"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* RIGHT SIDE: Scientific / Legal */}
      <div class="lg:col-span-3 space-y-6 min-w-0">
        <h4 class="text-[10px] font-mono font-bold text-mute uppercase tracking-[0.3em]">Scientific & Legal</h4>
        <ul class="space-y-4">
          {legalLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener noreferrer" : undefined}
                class="group flex items-center text-sm font-bold text-ink/60 hover:text-ink transition-colors duration-200"
              >
                {link.name}
                {link.external && <ArrowUpRight class="w-3 h-3 ml-1.5 opacity-0 group-hover:opacity-100 transition-all -translate-y-0.5" />}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* Bottom Row */}
    <div class="pt-8 border-t border-hairline/50 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-[10px] font-mono font-bold text-mute uppercase tracking-[0.1em] text-center md:text-left">
        &copy; {currentYear} QuickBMICalculator | Built by <span class="text-ink">Ayush Kumar Mishra</span>
      </div>
      <div class="text-[10px] font-mono font-bold text-mute uppercase tracking-[0.1em] opacity-60 text-center md:text-right">
        WHO Compliant &bull; Privacy First &bull; Real-Time Analysis
      </div>
    </div>
  </div>
</footer>
)}
