---
import HeroBackdrop from './HeroBackdrop.astro';

export interface Props {
	subtitle: string;
	badgeTag: string;
	badgeLine: string;
	calculatorId?: string;
}

const { subtitle, badgeTag, badgeLine, calculatorId = 'calculator' } = Astro.props;
---

<section class="relative pt-28 pb-16 sm:pt-32 sm:pb-20 lg:pt-40 lg:pb-28 px-4 sm:px-6 flex flex-col items-center bg-canvas -mt-20 overflow-hidden">
	<HeroBackdrop />

	<div class="w-full max-w-[940px] mx-auto text-center space-y-7 relative z-10">
		<slot name="hero-top" />

		<div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-accent/5 border border-accent/10 shadow-sm">
			<span class="text-[10px] font-mono font-bold text-accent uppercase tracking-[0.12em]">{badgeTag}</span>
			<span class="w-1.5 h-1.5 rounded-full bg-status-healthy shrink-0"></span>
			<span class="text-[10px] font-mono font-medium text-mute tracking-[0.04em]">{badgeLine}</span>
		</div>

		<h1 class="text-[clamp(2.8rem,6vw,6rem)] font-black tracking-[-0.03em] leading-[1.05] text-ink text-balance">
			<slot />
		</h1>

		<p class="text-base sm:text-lg text-mute max-w-[62ch] mx-auto leading-relaxed font-medium">
			{subtitle}
		</p>

		<div class="flex items-center justify-center pt-2">
			<a href={`#${calculatorId}`} class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-ink text-canvas text-[11px] font-mono font-bold uppercase tracking-[0.16em] hover:-translate-y-[1px] transition-all duration-300 shadow-premium-md hover:shadow-premium-lg">
				Calculate Now
				<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
		</div>

		<div class="pt-8 mt-8 border-t border-hairline">
			<div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
				<div class="flex items-center gap-2.5">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
					<div class="text-left">
						<span class="block text-[11px] font-mono font-bold text-ink uppercase tracking-[0.08em]">Instant</span>
						<span class="block text-[10px] text-mute font-medium">Results as you type</span>
					</div>
				</div>
				<div class="flex items-center gap-2.5">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
					<div class="text-left">
						<span class="block text-[11px] font-mono font-bold text-ink uppercase tracking-[0.08em]">Private</span>
						<span class="block text-[10px] text-mute font-medium">No account needed</span>
					</div>
				</div>
				<div class="flex items-center gap-2.5">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/><path d="M8.5 8.5v.01"/><path d="M16 15.5v.01"/><path d="M12 12v.01"/><path d="M11 17v.01"/><path d="M7 14v.01"/></svg>
					<div class="text-left">
						<span class="block text-[11px] font-mono font-bold text-ink uppercase tracking-[0.08em]">US & Metric</span>
						<span class="block text-[10px] text-mute font-medium">Your units, your way</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

