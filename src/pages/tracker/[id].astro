---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import Footer from '../../components/Footer.astro';
import HeroBackdrop from '../../components/HeroBackdrop.astro';
import { ProfileDashboard } from '../../components/tracker/ProfileDashboard';

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/tracker');
}

const title = "Profile Dashboard | QuickBMICalculator Tracker";
const description = "View your saved health reports and track your progress over time.";
---

<Layout title={title} description={description} robots="noindex, nofollow">
  <Navbar client:load />

  <main class="flex-grow pt-8 sm:pt-12 lg:pt-20 pb-24 px-4 sm:px-6 bg-canvas relative overflow-hidden min-h-[90vh]">
    <HeroBackdrop />

    <div class="w-full max-w-7xl mx-auto space-y-16 lg:space-y-24 relative z-10">
      <ProfileDashboard client:only="react" profileId={id} />
    </div>
  </main>

  <Footer />
</Layout>
