---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';
import { CalculatorCard } from '../components/calculator/CalculatorCard';
import { FAQAccordion } from '../components/FAQAccordion';
import { faqData } from '../data/faq';
import { AlertTriangle } from 'lucide-react';

const faqSchema = {
	"@type": "FAQPage",
	"@id": `${Astro.url.href}#faq`,
	"mainEntity": faqData.map(faq => ({
		"@type": "Question",
		"name": faq.q,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.a
		}
	}))
};
---

<Layout appName="BMI Calculator" extraSchema={[faqSchema]}>
	<Navbar client:load />

	<main class="flex-grow">
		{/* HERO SECTION - Refined Overlap & Visibility */}
		<section class="relative pt-20 pb-16 sm:pt-24 sm:pb-20 lg:pt-32 lg:pb-28 px-4 sm:px-6 flex flex-col items-center bg-canvas">
			
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none -z-10">
				<div class="absolute top-[-5%] left-1/2 -translate-x-1/2 w-[90%] sm:w-[80%] h-[80%] bg-[radial-gradient(circle,rgba(0,223,216,0.06)_0%,transparent_70%)] blur-[100px] sm:blur-[120px] rounded-full dark:opacity-[0.12]"></div>
				<div class="absolute top-[15%] left-1/2 -translate-x-1/2 w-[80%] sm:w-[70%] h-[60%] bg-[radial-gradient(circle,rgba(0,112,243,0.04)_0%,transparent_70%)] blur-[120px] sm:blur-[140px] rounded-full dark:opacity-[0.1]"></div>
			</div>

			<div class="max-w-4xl mx-auto text-center space-y-6 sm:space-y-8 relative z-10">
				<h1 class="text-[2.5rem] xs:text-[2.75rem] sm:text-5xl md:text-7xl lg:text-8xl xl:text-[10rem] font-black tracking-[-0.06em] leading-[0.9] sm:leading-[0.85] text-ink animate-fade-in">
					Calculate <br class="hidden sm:block" />
					Your <span class="tracking-normal bg-linear-to-r from-status-healthy to-status-under bg-clip-text text-transparent dark:bg-none dark:text-ink">BMI</span> <br class="hidden sm:block" />
					<span class="text-mute/60 italic font-medium">Instantly</span>
				</h1>
				
				<p class="text-base sm:text-xl lg:text-2xl text-body max-w-2xl mx-auto leading-tight tracking-tight font-medium opacity-70 px-4 sm:px-0">
					Understand your body mass index with a simple, real-time calculator based on standard WHO guidelines.
				</p>

				{/* TRUST ROW - Premium Balanced Density */}
				<div class="flex flex-wrap justify-center gap-2 sm:gap-4 lg:gap-5 pt-4 sm:pt-6 max-w-5xl mx-auto">
					{[
						{ label: 'Real-time Results', icon: '⚡' },
						{ label: 'WHO Standards', icon: '🏥' },
						{ label: 'Fitness Friendly', icon: '💪' },
						{ label: 'Mobile Optimized', icon: '📱' },
						{ label: 'Private & Secure', icon: '🔒' }
					].map((chip) => (
						<div class="flex-none inline-flex items-center justify-center gap-2 px-4 py-2 sm:px-6 sm:py-3 lg:px-8 rounded-full bg-canvas border border-hairline shadow-premium-sm hover:border-hairline-strong transition-all cursor-default group hover:shadow-premium-md">
							<span class="text-sm group-hover:scale-110 transition-transform">{chip.icon}</span>
							<span class="text-[10px] sm:text-xs font-bold uppercase tracking-widest text-ink whitespace-nowrap">{chip.label}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		{/* CALCULATOR PANEL - Seamless Grid Integration */}
		<section class="relative z-20 px-4 sm:px-6 w-full pt-4 sm:pt-8 lg:pt-10 mb-12 sm:mb-16 lg:mb-24">
			<div id="calculator" class="w-full max-w-6xl mx-auto relative animate-float">
				<div class="absolute -inset-10 sm:-inset-20 bg-primary/5 rounded-[40px] blur-[80px] sm:blur-[110px] dark:bg-white/5 opacity-30 pointer-events-none"></div>
				<CalculatorCard client:load />
			</div>
		</section>

		{/* WHY USE THIS BMI CALCULATOR? */}
		<section id="how-it-works" class="pt-16 pb-16 sm:pt-20 sm:pb-20 lg:pt-28 lg:pb-28 px-6 bg-canvas-soft border-y border-hairline relative">
			<div class="max-w-7xl mx-auto">
				<div class="mb-12 lg:mb-14 text-center max-w-3xl mx-auto">
					<h2 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tighter mb-6 text-ink leading-tight">Why Use This BMI Calculator?</h2>
					<p class="text-lg sm:text-xl text-body font-medium opacity-60">
						A simple, private, and lightning-fast tool to help you understand your health metrics.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
					{[
						{ title: 'Instant BMI Results', desc: 'No loading screens. See your exact index and category update instantly as you type.', icon: '⚡' },
						{ title: 'Metric + Imperial Support', desc: 'Seamlessly switch between US units (feet/lbs) and Metric (cm/kg) with zero math required.', icon: '⚖️' },
						{ title: 'WHO-Based Categories', desc: 'Get accurate classifications based directly on World Health Organization guidelines.', icon: '🏥' },
						{ title: 'Age & Gender Insights', desc: 'Optional profile inputs allow for tailored calorie and energy expenditure estimates.', icon: '👤' },
						{ title: 'Healthy Target Suggestions', desc: 'Automatically see the optimum weight range for your specific height to set healthy goals.', icon: '🎯' },
						{ title: 'Privacy Focused', desc: 'Your data stays right in your browser. We never store, track, or share your health metrics.', icon: '🔒' }
					].map((item, i) => (
						<div key={i} class="h-full card card-hover group p-10 lg:p-12 bg-canvas border-hairline shadow-premium-sm flex flex-col justify-start">
							<div class="text-3xl sm:text-4xl mb-6 group-hover:scale-110 transition-transform duration-500 origin-left drop-shadow-sm">{item.icon}</div>
							<h3 class="text-xl font-black tracking-tight mb-3 text-ink">{item.title}</h3>
							<p class="text-body text-sm leading-relaxed font-medium opacity-80">{item.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		{/* BMI CATEGORIES + RISK MATRIX - Perfect Optical Balance */}
		<section id="bmi-categories" class="pt-16 pb-16 sm:pt-20 sm:pb-20 lg:pt-28 lg:pb-28 px-6 bg-canvas border-b border-hairline relative">
			<div class="max-w-7xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
					
					{/* Left Column: Categories (45%) */}
					<div class="lg:col-span-5 flex flex-col space-y-8 lg:space-y-10 bg-canvas-soft/30 p-6 sm:p-12 lg:p-14 rounded-[2rem] border border-hairline shadow-premium-sm">
						<h2 class="text-4xl sm:text-5xl font-black tracking-tighter text-ink leading-tight">BMI <br class="hidden sm:block" /> Categories</h2>
						<div class="flex-1 flex flex-col justify-center overflow-hidden">
							<div class="overflow-x-auto -mx-6 px-6 sm:mx-0 sm:px-0">
								<table class="w-full text-left border-collapse shadow-premium-sm bg-canvas rounded-xl overflow-hidden border border-hairline">
										<thead>
											<tr class="border-b border-hairline bg-canvas-soft">
												<th class="py-4 px-5 sm:py-5 sm:px-8 text-[10px] font-mono font-black text-ink uppercase tracking-[0.2em]">Category</th>
												<th class="py-4 px-5 sm:py-5 sm:px-8 text-[10px] font-mono font-black text-ink uppercase tracking-[0.2em] text-right">Range</th>
											</tr>
										</thead>
										<tbody class="text-ink">
											{[
												{ cat: 'Severe Thinness', range: '< 16.0', color: 'bg-status-under' },
												{ cat: 'Moderate Thinness', range: '16.0 &ndash; 16.9', color: 'bg-status-under' },
												{ cat: 'Mild Thinness', range: '17.0 &ndash; 18.4', color: 'bg-status-under' },
												{ cat: 'Normal Weight', range: '18.5 &ndash; 24.9', color: 'bg-status-healthy' },
												{ cat: 'Overweight', range: '25.0 &ndash; 29.9', color: 'bg-status-over' },
												{ cat: 'Obesity Class I', range: '30.0 &ndash; 34.9', color: 'bg-status-obese' },
												{ cat: 'Obesity Class II', range: '35.0 &ndash; 39.9', color: 'bg-status-obese' },
												{ cat: 'Obesity Class III', range: '&ge; 40.0', color: 'bg-status-obese' },
											].map((row, i) => (
												<tr key={i} class="border-b border-hairline/60 hover:bg-canvas-soft transition-colors last:border-0 group">
													<td class="py-4 pl-5 sm:py-5 sm:pl-8 pr-4">
														<div class="flex items-center gap-3 sm:gap-4">
															<div class={`w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full ${row.color} opacity-30 group-hover:opacity-100 transition-all duration-500`}></div>
															<span class="font-black text-sm sm:text-base tracking-tight">{row.cat}</span>
														</div>
													</td>
													<td class="py-4 pr-5 sm:py-5 sm:pr-8 font-mono text-mute text-right tracking-tighter text-[10px] sm:text-sm font-bold">{row.range}</td>
												</tr>
											))}
										</tbody>
									</table>
								</div>
							</div>
						</div>

					{/* Right Column: Considerations (55%) */}
					<div class="lg:col-span-7 flex flex-col space-y-8 lg:space-y-10 bg-canvas-soft/30 p-6 sm:p-12 lg:p-14 rounded-[2rem] border border-hairline shadow-premium-sm">
						<h2 class="text-4xl sm:text-5xl font-black tracking-tighter text-ink leading-tight">Health <br class="hidden sm:block" /> Considerations</h2>
						<div class="flex-1 flex flex-col justify-center space-y-4 sm:space-y-8">
							{[
								{ title: 'Cardiovascular', desc: 'Excess weight increases the workload on the heart, raising risks of hypertension.' },
								{ title: 'Metabolic Impact', desc: 'High body mass is often linked to insulin resistance and Type 2 Diabetes.' },
								{ title: 'Respiratory Health', desc: 'Increased weight around the chest can impact lung expansion and sleep quality.' }
							].map((limit, i) => (
								<div key={i} class="flex flex-col xs:flex-row gap-4 sm:gap-8 group p-5 sm:p-8 rounded-2xl border border-transparent hover:border-hairline hover:bg-canvas transition-all shadow-none hover:shadow-premium-sm">
									<div class="w-10 h-10 sm:w-14 sm:h-14 rounded-full border border-hairline flex items-center justify-center shrink-0 mt-1 text-[10px] sm:text-sm font-mono font-bold text-ink bg-canvas-soft group-hover:bg-ink group-hover:text-canvas transition-all shadow-premium-sm">0{i+1}</div>
									<div>
										<h4 class="font-black mb-2 sm:mb-3 text-ink text-lg sm:text-2xl tracking-tight">{limit.title}</h4>
										<p class="text-xs sm:text-base text-body leading-relaxed font-medium opacity-80">{limit.desc}</p>
									</div>
								</div>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		{/* FAQ SECTION - Expanded & Interactive */}
		<section id="faq" class="py-16 sm:py-20 lg:py-28 px-6 bg-canvas relative z-10 border-b border-hairline">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-12 lg:mb-14">
					<h2 class="text-4xl sm:text-6xl font-black tracking-tighter mb-6 sm:mb-8 text-ink text-gradient leading-none">Expert knowledge</h2>
					<p class="text-lg sm:text-xl text-body max-w-2xl mx-auto tracking-tight font-medium opacity-60">Common questions and helpful answers about your BMI results.</p>
				</div>
				
				<FAQAccordion client:visible faqs={faqData} />
			</div>
		</section>

		{/* SEO CONTENT SECTION - Editorial Reading Experience */}
		<section class="py-16 sm:py-20 lg:py-28 px-6 bg-canvas-soft relative z-10 border-b border-hairline">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12 lg:mb-14">
					<h2 class="text-3xl sm:text-5xl lg:text-6xl font-black tracking-tighter text-ink leading-tight">BMI Knowledge Base</h2>
					<p class="text-lg sm:text-xl text-body font-medium opacity-70 mt-6 max-w-2xl mx-auto">Essential insights for tracking and managing your wellness safely and accurately.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
					<div class="flex flex-col h-full card bg-canvas border-hairline p-10 lg:p-12 hover:border-hairline-strong transition-colors shadow-premium-sm">
						<h3 class="text-2xl font-black tracking-tight text-ink mb-6">Understanding BMI</h3>
						<p class="text-body leading-relaxed font-medium opacity-80 text-base">
							Tracking your body metrics is a simple step toward better wellness. A <strong>BMI calculator</strong> offers an accessible way to estimate if your weight is in healthy proportion to your height. Whether you are using a bmi calculator for men to monitor fitness, or a bmi calculator for women for everyday tracking, this tool is a helpful starting point.
						</p>
					</div>

					<div class="flex flex-col h-full card bg-canvas border-hairline p-10 lg:p-12 hover:border-hairline-strong transition-colors shadow-premium-sm">
						<h3 class="text-2xl font-black tracking-tight text-ink mb-6">How BMI Works</h3>
						<p class="text-body leading-relaxed font-medium opacity-80 text-base">
							The formula is universally recognized by health professionals. For those using a bmi calculator kg, it divides weight in kilograms by height in meters squared. Prefer a bmi calculator in kg and feet? Our online bmi calculator handles all unit conversions automatically, making it easy for users worldwide—including those looking for a bmi calculator india.
						</p>
					</div>

					<div class="flex flex-col h-full card bg-canvas border-hairline p-10 lg:p-12 hover:border-hairline-strong transition-colors shadow-premium-sm">
						<h3 class="text-2xl font-black tracking-tight text-ink mb-6">Age and Gender Context</h3>
						<p class="text-body leading-relaxed font-medium opacity-80 text-base">
							Many wonder if a bmi calculator by age gives different results. While the math stays the same, the interpretation of a bmi calculator women age result can shift. Older adults may have different recommended weight ranges to maintain bone health. For a bmi calculator for kids, health professionals use specific percentile growth charts instead of adult thresholds.
						</p>
					</div>

					<div class="flex flex-col h-full card bg-canvas border-hairline p-10 lg:p-12 hover:border-hairline-strong transition-colors shadow-premium-sm">
						<h3 class="text-2xl font-black tracking-tight text-ink mb-6">Limitations of BMI</h3>
						<p class="text-body leading-relaxed font-medium opacity-80 text-base">
							While a highly useful online bmi calculator, it is not a perfect metric. BMI cannot distinguish between fat and muscle mass, meaning athletic users looking for a bmi calculator male standard might see skewed results. It also does not account for bone density or fat distribution, so it should be used alongside other health indicators.
						</p>
					</div>
				</div>
			</div>
		</section>

		{/* MEDICAL DISCLAIMER - Single, Premium Card Before Footer */}
		<section class="py-12 sm:py-16 px-6 bg-canvas relative z-20 pb-24 sm:pb-32">
			<div class="max-w-5xl mx-auto">
				<div class="bg-[#f5a623]/5 border border-[#f5a623]/20 p-8 sm:p-10 rounded-2xl flex flex-col sm:flex-row gap-6 sm:gap-8 items-start shadow-premium-sm dark:bg-[#f5a623]/10">
					<div class="shrink-0 mt-1 bg-canvas p-3 rounded-xl shadow-premium-sm border border-hairline">
						<AlertTriangle class="w-8 h-8 text-[#f5a623]" />
					</div>
					<div>
						<h4 class="text-[#f5a623] font-black tracking-widest uppercase text-xs sm:text-sm mb-3">Important Medical Disclaimer</h4>
						<p class="text-base text-body leading-relaxed m-0 font-medium opacity-90">
							This BMI calculator is provided for informational and educational purposes only. It is not a substitute for professional medical advice, diagnosis, or treatment. BMI has limitations—it cannot distinguish between fat and muscle mass, nor does it account for bone density. Always consult with a qualified healthcare provider or doctor regarding any questions you may have about your weight, health, or medical conditions.
						</p>
					</div>
				</div>
			</div>
		</section>

	</main>

	<Footer />
</Layout>

<style>
	.animate-float {
		animation: float 6s ease-in-out infinite;
	}
</style>
