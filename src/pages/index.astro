---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';
import HeroCalculator from '../components/HeroCalculator.astro';
import { CalculatorCard } from '../components/calculator/CalculatorCard';
import { FAQAccordion } from '../components/FAQAccordion';
import { faqData } from '../data/faq';
import { AlertTriangle } from 'lucide-react';

const faqSchema = {
	"@type": "FAQPage",
	"@id": `${Astro.url.href}#faq`,
	"mainEntity": faqData.map(faq => ({
		"@type": "Question",
		"name": faq.q,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.a
		}
	}))
};
---

<Layout appName="BMI Calculator" extraSchema={[faqSchema]}>
	<Navbar client:load />

	<main class="flex-grow bg-canvas">
		<HeroCalculator
			subtitle="A complete health calculator platform designed to help you understand your body, nutrition, hydration, and fitness goals with instant results and actionable insights."
			badgeTag="WHO Standard"
			badgeLine="World Health Organization ranges"
		>
			<div slot="hero-top" class="w-full overflow-hidden whitespace-nowrap relative py-1.5 border-y border-hairline/20 mb-6 mask-gradient">
				<div class="animate-marquee-custom flex gap-16 items-center text-[10px] sm:text-xs font-mono font-bold uppercase tracking-[0.2em] text-mute select-none">
					<span>BMI • BMR • Body Fat • Calorie • Daily Nutrition • Ideal Weight • Lean Body Mass • Macro • Protein • Water Intake</span>
					<span>BMI • BMR • Body Fat • Calorie • Daily Nutrition • Ideal Weight • Lean Body Mass • Macro • Protein • Water Intake</span>
				</div>
			</div>
			Calculate <span class="text-accent">BMI</span> <br class="hidden sm:block" />
			& Track Your <br class="hidden sm:block" />
			Health
		</HeroCalculator>

		{/* CALCULATOR PANEL - Seamless Grid Integration */}
		<section class="relative z-20 px-4 sm:px-6 w-full pt-0 pb-20 lg:pb-28">
			<div id="calculator" class="w-full max-w-6xl mx-auto relative animate-float">
				<div class="absolute -inset-10 sm:-inset-20 bg-primary/5 rounded-[40px] blur-[80px] sm:blur-[110px] dark:bg-white/5 opacity-30 pointer-events-none"></div>
				<CalculatorCard client:load />
			</div>
		</section>

		{/* WHY USE THIS BMI CALCULATOR? */}
		<section id="how-it-works" class="py-16 lg:py-20 px-6 bg-canvas-soft border-y border-hairline relative">
			<div class="max-w-7xl mx-auto">
				<div class="mb-12 lg:mb-14 text-center max-w-3xl mx-auto">
					<h2 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tighter mb-6 text-ink leading-tight text-balance">Why Use This BMI Calculator?</h2>
					<p class="text-lg sm:text-xl text-body font-medium opacity-60 text-pretty">
						A simple, private, and lightning-fast tool to help you understand your health metrics.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
					{[
						{ title: 'Instant BMI Results', desc: 'No loading screens. See your exact index and category update instantly as you type.', icon: '⚡' },
						{ title: 'Metric + Imperial Support', desc: 'Seamlessly switch between US units (feet/lbs) and Metric (cm/kg) with zero math required.', icon: '⚖️' },
						{ title: 'WHO-Based Categories', desc: 'Get accurate classifications based directly on World Health Organization guidelines.', icon: '🏥' },
						{ title: 'Age & Gender Insights', desc: 'Optional profile inputs allow for tailored calorie and energy expenditure estimates.', icon: '👤' },
						{ title: 'Healthy Target Suggestions', desc: 'Automatically see the optimum weight range for your specific height to set healthy goals.', icon: '🎯' },
						{ title: 'Privacy Focused', desc: 'Your data stays right in your browser. We never store, track, or share your health metrics.', icon: '🔒' }
					].map((item, i) => (
						<div key={i} class={`h-full card card-hover group p-10 lg:p-12 flex flex-col justify-start ${i === 0 ? 'bg-ink text-canvas border border-hairline/10 dark:bg-canvas dark:text-ink lg:col-span-2 md:col-span-2' : i === 5 ? 'bg-canvas border-hairline text-ink lg:col-span-3 md:col-span-2' : 'bg-canvas border-hairline text-ink'}`}>
							<div class="text-3xl sm:text-4xl mb-6 group-hover:scale-110 transition-transform duration-500 origin-left drop-shadow-sm">{item.icon}</div>
							<h3 class={`text-xl font-black tracking-tight mb-3 text-balance ${i === 0 ? 'text-canvas dark:text-ink' : 'text-ink'}`}>{item.title}</h3>
							<p class={`text-sm leading-relaxed font-medium text-pretty ${i === 0 ? 'text-canvas-soft/80 dark:text-body' : 'text-body opacity-80'}`}>{item.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		{/* BMI CATEGORIES + RISK MATRIX - Perfect Optical Balance */}
		<section id="bmi-categories" class="py-16 lg:py-20 px-6 bg-canvas border-b border-hairline relative">
			<div class="max-w-7xl mx-auto flex flex-col space-y-12 lg:space-y-16">
				
				{/* BMI Categories (Full-Width Stacked) */}
				<div class="w-full">
					<div class="flex flex-col gap-3 mb-12 px-6 sm:px-10 lg:px-12">
						<span class="block font-mono text-xs uppercase tracking-[0.16em] text-mute font-medium">Reference</span>
						<h2 class="text-[clamp(2rem,3.4vw,2.9rem)] font-bold tracking-[-0.02em] text-ink text-balance">BMI categories</h2>
						<p class="text-lg lg:text-xl text-mute leading-snug max-w-[52ch]">Where every index falls, based on WHO thresholds. Your result is highlighted.</p>
					</div>

					<div class="bg-surface border border-hairline rounded-marketing p-6 sm:p-10 lg:p-12">
						<table class="w-full border-collapse">
							<thead class="sr-only"><tr><th>Category</th><th>Range</th></tr></thead>
							<tbody class="flex flex-col gap-0.5">
								{[
									{ cat: 'Severe Thinness', range: '< 16.0', color: 'bg-status-under', left: '0%', width: '15%' },
									{ cat: 'Moderate Thinness', range: '16.0 &ndash; 16.9', color: 'bg-status-under', left: '15%', width: '10%' },
									{ cat: 'Mild Thinness', range: '17.0 &ndash; 18.4', color: 'bg-status-under', left: '25%', width: '10%' },
									{ cat: 'Normal Weight', range: '18.5 &ndash; 24.9', color: 'bg-status-healthy', left: '35%', width: '25%' },
									{ cat: 'Overweight', range: '25.0 &ndash; 29.9', color: 'bg-status-over', left: '60%', width: '15%' },
									{ cat: 'Obesity Class I', range: '30.0 &ndash; 34.9', color: 'bg-status-obese', left: '75%', width: '10%' },
									{ cat: 'Obesity Class II', range: '35.0 &ndash; 39.9', color: 'bg-status-obese', left: '85%', width: '10%' },
									{ cat: 'Obesity Class III', range: '&ge; 40.0', color: 'bg-status-obese', left: '95%', width: '5%' },
								].map((row, i) => (
									<tr key={i} class="grid grid-cols-[140px_1fr] sm:grid-cols-[180px_1fr_120px] items-center gap-3 sm:gap-4 px-3 sm:px-4 py-3 rounded-[12px] hover:bg-surface-2 transition-colors">
										<td class="font-semibold text-[0.95rem] text-ink truncate">{row.cat}</td>
										<td>
											<div class="relative h-2.5 rounded-full bg-hairline overflow-hidden">
												<div class={`absolute h-full ${row.color} rounded-full`} style={{ left: row.left, width: row.width }}></div>
											</div>
										</td>
										<td class="hidden sm:block font-mono text-sm text-right text-ink-soft font-medium whitespace-nowrap" set:html={row.range}></td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>

				{/* Health Considerations (Full-Width Stacked) */}
				<div class="w-full">
					<div class="flex flex-col gap-3 mb-12 px-6 sm:px-10 lg:px-12">
						<span class="block font-mono text-xs uppercase tracking-[0.16em] text-mute font-medium">Guidance</span>
						<h2 class="text-[clamp(2rem,3.4vw,2.9rem)] font-bold tracking-[-0.02em] text-ink text-balance">Health Considerations</h2>
						<p class="text-lg lg:text-xl text-mute leading-snug max-w-[52ch]">What a higher BMI can mean for your body, and where to pay attention.</p>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-hairline rounded-marketing overflow-hidden border border-hairline">
						{[
							{ title: 'Cardiovascular', desc: 'Excess weight increases the workload on the heart, raising risks of hypertension.' },
							{ title: 'Metabolic Impact', desc: 'High body mass is often linked to insulin resistance and Type 2 Diabetes.' },
							{ title: 'Respiratory Health', desc: 'Increased weight around the chest can impact lung expansion and sleep quality.' }
						].map((limit, i) => (
							<div key={i} class="bg-surface p-8 flex flex-col gap-3">
								<span class="font-mono text-sm text-mute">0{i+1}</span>
								<h3 class="text-xl font-bold tracking-[-0.01em] text-ink">{limit.title}</h3>
								<p class="text-sm text-mute leading-relaxed">{limit.desc}</p>
							</div>
						))}
					</div>
				</div>

			</div>
		</section>

		{/* FAQ SECTION - Expanded & Interactive */}
		<section id="faq" class="py-16 lg:py-20 px-6 bg-canvas relative z-10 border-b border-hairline">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-12 lg:mb-14">
					<h2 class="text-4xl sm:text-6xl font-black tracking-tighter mb-6 sm:mb-8 text-ink text-gradient leading-none text-balance">Expert knowledge</h2>
					<p class="text-lg sm:text-xl text-body max-w-2xl mx-auto tracking-tight font-medium opacity-60 text-pretty">Common questions and helpful answers about your BMI results.</p>
				</div>
				
				<FAQAccordion client:visible faqs={faqData} />
			</div>
		</section>

		{/* SEO CONTENT SECTION - Editorial Reading Experience */}
		<section class="py-16 lg:py-20 px-6 bg-canvas-soft relative z-10 border-b border-hairline">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-12 lg:mb-14">
					<h2 class="text-3xl sm:text-5xl lg:text-6xl font-black tracking-tighter text-ink leading-tight text-balance">BMI Knowledge Base</h2>
					<p class="text-lg sm:text-xl text-body font-medium opacity-70 mt-6 max-w-2xl mx-auto text-pretty">Essential insights for tracking and managing your wellness safely and accurately.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
					<div class="flex flex-col h-full card bg-canvas border-hairline p-10 lg:p-12 hover:border-hairline-strong transition-colors shadow-premium-sm">
						<h3 class="text-2xl font-black tracking-tight text-ink mb-6 text-balance">Understanding BMI</h3>
						<p class="text-body leading-relaxed font-medium opacity-80 text-base text-pretty">
							Tracking your body metrics is a simple step toward better wellness. A <strong>BMI calculator</strong> offers an accessible way to estimate if your weight is in healthy proportion to your height. Whether you are using a bmi calculator for men to monitor fitness, or a bmi calculator for women for everyday tracking, this tool is a helpful starting point.
						</p>
					</div>

					<div class="flex flex-col h-full card bg-canvas border-hairline p-10 lg:p-12 hover:border-hairline-strong transition-colors shadow-premium-sm">
						<h3 class="text-2xl font-black tracking-tight text-ink mb-6 text-balance">How BMI Works</h3>
						<p class="text-body leading-relaxed font-medium opacity-80 text-base text-pretty">
							The formula is universally recognized by health professionals. For those using a bmi calculator kg, it divides weight in kilograms by height in meters squared. Prefer a bmi calculator in kg and feet? Our online bmi calculator handles all unit conversions automatically, making it easy for users worldwide—including those looking for a bmi calculator india.
						</p>
					</div>

					<div class="flex flex-col h-full card bg-canvas border-hairline p-10 lg:p-12 hover:border-hairline-strong transition-colors shadow-premium-sm">
						<h3 class="text-2xl font-black tracking-tight text-ink mb-6 text-balance">Age and Gender Context</h3>
						<p class="text-body leading-relaxed font-medium opacity-80 text-base text-pretty">
							Many wonder if a bmi calculator by age gives different results. While the math stays the same, the interpretation of a bmi calculator women age result can shift. Older adults may have different recommended weight ranges to maintain bone health. For a bmi calculator for kids, health professionals use specific percentile growth charts instead of adult thresholds.
						</p>
					</div>

					<div class="flex flex-col h-full card bg-canvas border-hairline p-10 lg:p-12 hover:border-hairline-strong transition-colors shadow-premium-sm">
						<h3 class="text-2xl font-black tracking-tight text-ink mb-6 text-balance">Limitations of BMI</h3>
						<p class="text-body leading-relaxed font-medium opacity-80 text-base text-pretty">
							While a highly useful online bmi calculator, it is not a perfect metric. BMI cannot distinguish between fat and muscle mass, meaning athletic users looking for a bmi calculator male standard might see skewed results. It also does not account for bone density or fat distribution, so it should be used alongside other health indicators.
						</p>
					</div>
				</div>
			</div>
		</section>

		{/* MEDICAL DISCLAIMER - Single, Premium Card Before Footer */}
		<section class="py-16 lg:py-20 px-6 bg-canvas relative z-20">
			<div class="max-w-5xl mx-auto">
				<div class="bg-[#f5a623]/5 border border-[#f5a623]/20 p-8 sm:p-10 rounded-2xl flex flex-col sm:flex-row gap-6 sm:gap-8 items-start shadow-premium-sm dark:bg-[#f5a623]/10">
					<div class="shrink-0 mt-1 bg-canvas p-3 rounded-xl shadow-premium-sm border border-hairline">
						<AlertTriangle class="w-8 h-8 text-[#f5a623]" />
					</div>
					<div>
						<h4 class="text-[#f5a623] font-black tracking-widest uppercase text-xs sm:text-sm mb-3 text-balance">Important Medical Disclaimer</h4>
						<p class="text-base text-body leading-relaxed m-0 font-medium opacity-90 text-pretty">
							This BMI calculator is provided for informational and educational purposes only. It is not a substitute for professional medical advice, diagnosis, or treatment. BMI has limitations—it cannot distinguish between fat and muscle mass, nor does it account for bone density. Always consult with a qualified healthcare provider or doctor regarding any questions you may have about your weight, health, or medical conditions.
						</p>
					</div>
				</div>
			</div>
		</section>

	</main>

	<Footer />
</Layout>

<style is:global>
	.animate-float {
		animation: float 6s ease-in-out infinite;
	}
	@keyframes marquee {
		0% { transform: translateX(0%); }
		100% { transform: translateX(-50%); }
	}
	.animate-marquee-custom {
		display: inline-flex;
		animation: marquee 25s linear infinite;
	}
	.animate-marquee-custom:hover {
		animation-play-state: paused;
	}
	.mask-gradient {
		mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
		-webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
	}
</style>
