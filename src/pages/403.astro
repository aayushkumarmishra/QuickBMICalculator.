---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';
---

<Layout title="403: Access Forbidden | QuickBMI" description="You do not have permission to access this page. Return to QuickBMI to calculate your Body Mass Index (BMI) easily." robots="noindex, nofollow">
	<Navbar client:load />

	<main class="min-h-[70vh] flex flex-col items-center pt-32 pb-20 relative overflow-hidden px-4">
		{/* Background Gradients */}
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none -z-10">
			<div class="absolute top-[10%] left-1/2 -translate-x-1/2 w-[90%] h-[80%] bg-[radial-gradient(circle,rgba(255,165,0,0.06)_0%,transparent_70%)] blur-[100px] rounded-full dark:opacity-[0.12]"></div>
			<div class="absolute top-[30%] left-1/2 -translate-x-1/2 w-[80%] h-[60%] bg-[radial-gradient(circle,rgba(0,0,0,0.04)_0%,transparent_70%)] blur-[120px] rounded-full dark:opacity-[0.1]"></div>
		</div>

		<div class="max-w-2xl mx-auto text-center space-y-8 relative z-10">
			<div class="space-y-4">
				<span class="inline-block px-4 py-1.5 rounded-full bg-canvas border border-hairline shadow-premium-sm text-[10px] font-mono font-black uppercase tracking-[0.2em] text-mute">
					Error 403
				</span>
				<h1 class="text-6xl sm:text-8xl lg:text-9xl font-black tracking-[-0.06em] leading-[0.85] text-ink">
					Access <br />
					<span class="text-mute/60 italic font-medium">Denied</span>
				</h1>
			</div>
			
			<p class="text-lg sm:text-xl text-body max-w-md mx-auto leading-tight tracking-tight font-medium opacity-70">
				You don't have the necessary permissions to view this resource. If you think this is an error, please contact us.
			</p>

			<div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
				<a 
					href="/" 
					class="w-full sm:w-auto px-8 py-4 rounded-full bg-ink text-canvas font-bold text-sm hover:scale-[1.02] transition-transform shadow-premium-md text-center"
				>
					Go Home
				</a>
				<a 
					href="/contact" 
					class="w-full sm:w-auto px-8 py-4 rounded-full bg-canvas text-ink border border-hairline font-bold text-sm hover:bg-canvas-soft transition-colors shadow-premium-sm text-center"
				>
					Contact Support
				</a>
			</div>
		</div>
	</main>

	<Footer />
</Layout>
