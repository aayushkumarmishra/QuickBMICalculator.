---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';
import HeroBackdrop from '../components/HeroBackdrop.astro';
import { BrandLogo } from '../components/BrandLogo';

const title = "About Us - QuickBMICalculator";
const description = "Discover the story behind QuickBMI. A modern BMI intelligence platform focused on accurate, real-time health insights based on WHO standards.";
---

<Layout title={title} description={description}>
	<Navbar client:load />

	<main class="flex-grow pt-12 sm:pt-20 pb-40 px-6 relative overflow-hidden bg-canvas">
		<HeroBackdrop />
		<article class="max-w-4xl mx-auto space-y-16">
			<header class="space-y-8 text-center">
				<div class="inline-flex items-center justify-center p-4 bg-canvas-soft rounded-[2rem] border border-hairline shadow-premium-sm mb-4">
					<BrandLogo className="w-16 h-16" />
				</div>
				<h1 class="text-4xl xs:text-5xl sm:text-7xl lg:text-8xl font-black tracking-tighter text-ink leading-[0.9]">
					BMI Intelligence <br />
					<span class="text-accent">Redefined</span>
				</h1>
				<p class="text-lg sm:text-xl sm:text-2xl text-body max-w-2xl mx-auto leading-relaxed font-medium opacity-70">
					A modern platform focused on providing accurate, real-time BMI insights with a focus on privacy and precision.
				</p>
			</header>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
				<section class="space-y-6 p-10 bg-canvas-soft rounded-[2rem] border border-hairline shadow-premium-sm">
					<h2 class="text-2xl font-black tracking-tight text-ink">The Mission</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						QuickBMICalculator was built to simplify health tracking. We believe that understanding your body metrics should be fast, private, and accessible to everyone. By combining modern web technology with established health standards, we provide a tool that works instantly on any device.
					</p>
				</section>

				<section class="space-y-6 p-10 bg-canvas-soft rounded-[2rem] border border-hairline shadow-premium-sm">
					<h2 class="text-2xl font-black tracking-tight text-ink">WHO Standards</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						Precision is our priority. Our calculations are based directly on the World Health Organization (WHO) guidelines for Body Mass Index. We handle both Metric and Imperial units with zero-error conversions, ensuring your results are always scientifically grounded.
					</p>
				</section>
			</div>

			<section class="space-y-10 text-center py-10">
				<h2 class="text-3xl sm:text-4xl font-black tracking-tighter text-ink">Core Principles</h2>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
					{[
						{ title: 'Privacy First', desc: 'No data ever leaves your device.' },
						{ title: 'Real-time', desc: 'Results update as you type.' },
						{ title: 'Accessible', desc: 'Universal design for all users.' }
					].map((item, i) => (
						<div class="space-y-3">
							<div class="text-4xl mb-4">0{i+1}</div>
							<h3 class="text-xl font-black tracking-tight text-ink">{item.title}</h3>
							<p class="text-sm text-body font-medium opacity-60">{item.desc}</p>
						</div>
					))}
				</div>
			</section>

			<div class="text-center pt-10 border-t border-hairline">
				<p class="text-mute font-mono text-xs uppercase tracking-[0.2em]">
					Empowering Health Awareness Through Technology
				</p>
			</div>
		</article>
	</main>

	<Footer />
</Layout>
