---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';

const title = "Terms & Conditions - QuickBMI";
const description = "Review the terms of use for QuickBMI. Understand our medical disclaimers and how to use our BMI platform safely.";
---

<Layout title={title} description={description}>
	<Navbar client:load />

	<main class="pt-32 pb-20 px-6">
		<article class="max-w-3xl mx-auto space-y-12">
			<header class="space-y-4">
				<h1 class="text-4xl sm:text-6xl font-black tracking-tighter text-ink leading-none">Terms of Use</h1>
				<p class="text-mute font-mono text-xs uppercase tracking-widest">Last Updated: June 4, 2026</p>
			</header>

			<section class="prose prose-ink dark:prose-invert max-w-none space-y-8">
				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">1. Acceptance of Terms</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						By accessing and using QuickBMI, you agree to be bound by these Terms of Use and all applicable laws and regulations. If you do not agree with any of these terms, you are prohibited from using or accessing this site.
					</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">2. Informational Purpose</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						QuickBMI is provided as a tool for informational and educational purposes only. The calculations and insights provided are based on the World Health Organization (WHO) standards but should not be treated as professional medical diagnosis or treatment.
					</p>
				</div>

				<div class="space-y-4 text-[#f5a623] bg-[#f5a623]/5 p-6 rounded-2xl border border-[#f5a623]/20 dark:bg-[#f5a623]/10">
					<h2 class="text-xl font-black tracking-tight mb-2">3. Medical Disclaimer</h2>
					<p class="text-sm leading-relaxed font-medium">
						BMI is a generalized measure and does not account for muscle mass, bone density, overall body composition, or ethnic differences. It is not a substitute for clinical judgment. Always seek the advice of your physician or other qualified health provider with any questions you may have regarding a medical condition.
					</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">4. Limitation of Liability</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						In no event shall QuickBMI or its creators be liable for any damages (including, without limitation, damages for loss of data or profit, or due to business interruption) arising out of the use or inability to use the materials on QuickBMI, even if we have been notified orally or in writing of the possibility of such damage.
					</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">5. Fair Use</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						You agree to use this website only for lawful purposes. You are prohibited from attempting to reverse engineer, scrape, or disrupt the services provided by QuickBMI.
					</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">6. External Links</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						QuickBMI may contain links to external sites (such as WHO guidelines). We are not responsible for the content or privacy practices of these external sites.
					</p>
				</div>
			</section>
		</article>
	</main>

	<Footer />
</Layout>
