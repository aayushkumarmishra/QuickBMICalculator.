---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';
import HeroCalculator from '../components/HeroCalculator.astro';
import { IdealWeightCalculatorCard } from '../components/calculator/IdealWeightCalculatorCard';
import { FAQAccordion } from '../components/FAQAccordion';
import { idealWeightFaqs } from '../data/faq';

const faqSchema = {
	"@type": "FAQPage",
	"@id": `${Astro.url.href}#faq`,
	"mainEntity": idealWeightFaqs.map(faq => ({
		"@type": "Question",
		"name": faq.q,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.a
		}
	}))
};
---

<Layout 
  title="Ideal Weight Calculator – Healthy Weight Range by Height"
  description="Find your ideal weight and healthy weight range using your height, gender, and body measurements."
  appName="Ideal Weight Calculator"
  extraSchema={[faqSchema]}
>
  <Navbar client:load />

  <main class="flex-grow">
    <HeroCalculator
      subtitle="Find your ideal weight and healthy weight range based on your unique profile and the scientifically validated Devine formula."
      badgeTag="Devine Formula"
      badgeLine="Clinically referenced range"
    >
      <span class="text-accent">Ideal</span> Weight
    </HeroCalculator>

    <section id="calculator" class="relative z-20 px-4 sm:px-6 pt-4 sm:pt-8 lg:pt-10 pb-16 sm:pb-24">
      <IdealWeightCalculatorCard client:load />
    </section>

    <section class="py-16 lg:py-20 px-6 bg-canvas-soft border-y border-hairline">
      <div class="max-w-4xl mx-auto space-y-6">
        <h2 class="text-3xl sm:text-4xl font-black tracking-tighter text-ink">Understanding Ideal Weight</h2>
        <p class="text-body leading-relaxed font-medium opacity-80 text-base">
          Ideal weight is a benchmark used to assess what a healthy weight might be for an individual based on their height and gender. While there are several formulas used to calculate this, the <strong>Devine Formula</strong> is one of the most widely recognized in medical and clinical settings.
        </p>
        <p class="text-body leading-relaxed font-medium opacity-80 text-base">
          It's important to remember that "ideal weight" is an estimate and doesn't account for body composition, such as muscle mass versus fat. Therefore, we also provide a <strong>Healthy Weight Range</strong> based on a standard BMI of 18.5 to 24.9, which offers a broader perspective on your health.
        </p>
      </div>
    </section>

    <section id="faq" class="py-16 lg:py-20 px-6 bg-canvas relative z-10 border-b border-hairline">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12 lg:mb-14">
          <h2 class="text-4xl sm:text-6xl font-black tracking-tighter mb-6 sm:mb-8 text-ink leading-none">Your ideal weight</h2>
          <p class="text-lg sm:text-xl text-body max-w-2xl mx-auto tracking-tight font-medium opacity-60">Common questions about ideal weight formulas and healthy weight ranges.</p>
        </div>
        
        <FAQAccordion client:visible faqs={idealWeightFaqs} />
      </div>
    </section>

    <section class="py-16 lg:py-20 px-6 bg-canvas border-b border-hairline">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm text-mute font-medium">
          Need to check your BMI? Try our 
          <a href="/" class="text-ink font-bold underline underline-offset-2 hover:text-status-healthy transition-colors">BMI Calculator</a>
          or calculate your 
          <a href="/calorie-calculator" class="text-ink font-bold underline underline-offset-2 hover:text-status-healthy transition-colors">Daily Calories</a>.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
