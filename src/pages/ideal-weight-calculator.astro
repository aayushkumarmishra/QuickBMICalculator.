---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer';
import { IdealWeightCalculatorCard } from '../components/calculator/IdealWeightCalculatorCard';
---

<Layout 
  title="Ideal Weight Calculator – Healthy Weight Range by Height"
  description="Find your ideal weight and healthy weight range using your height, gender, and body measurements."
  canonical="https://quickbmicalculator.com/ideal-weight-calculator/"
>
  <Navbar client:load />

  <main class="flex-grow">
    <section class="relative pt-16 pb-16 sm:pt-24 sm:pb-20 lg:pb-28 px-4 sm:px-6 flex flex-col items-center bg-canvas">
      <div class="max-w-4xl mx-auto text-center space-y-4 sm:space-y-6 relative z-10">
        <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black tracking-[-0.06em] leading-[0.9] text-ink">
          <span class="tracking-normal bg-linear-to-r from-status-healthy to-status-under bg-clip-text text-transparent dark:bg-none dark:text-ink">Ideal</span> Weight
        </h1>
        <p class="text-base sm:text-xl text-body max-w-2xl mx-auto leading-tight font-medium opacity-70">
          Find your ideal weight and healthy weight range based on your unique profile and the scientifically validated Devine formula.
        </p>
      </div>
    </section>

    <section class="relative z-20 px-4 sm:px-6 pt-4 sm:pt-8 lg:pt-10 mb-12 sm:mb-16 lg:mb-24 pb-16 sm:pb-24">
      <IdealWeightCalculatorCard client:load />
    </section>

    <section class="py-12 sm:py-16 px-6 bg-canvas-soft border-y border-hairline">
      <div class="max-w-4xl mx-auto space-y-6">
        <h2 class="text-3xl sm:text-4xl font-black tracking-tighter text-ink">Understanding Ideal Weight</h2>
        <p class="text-body leading-relaxed font-medium opacity-80 text-base">
          Ideal weight is a benchmark used to assess what a healthy weight might be for an individual based on their height and gender. While there are several formulas used to calculate this, the <strong>Devine Formula</strong> is one of the most widely recognized in medical and clinical settings.
        </p>
        <p class="text-body leading-relaxed font-medium opacity-80 text-base">
          It's important to remember that "ideal weight" is an estimate and doesn't account for body composition, such as muscle mass versus fat. Therefore, we also provide a <strong>Healthy Weight Range</strong> based on a standard BMI of 18.5 to 24.9, which offers a broader perspective on your health.
        </p>
      </div>
    </section>

    <section class="py-12 px-6 bg-canvas border-b border-hairline">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm text-mute font-medium">
          Need to check your BMI? Try our 
          <a href="/" class="text-ink font-bold underline underline-offset-2 hover:text-status-healthy transition-colors">BMI Calculator</a>
          or calculate your 
          <a href="/calorie-calculator" class="text-ink font-bold underline underline-offset-2 hover:text-status-healthy transition-colors">Daily Calories</a>.
        </p>
      </div>
    </section>
  </main>

  <Footer client:visible />
</Layout>
