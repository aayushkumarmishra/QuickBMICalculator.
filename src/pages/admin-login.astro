---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';
import { AuthForm } from '../components/auth/AuthForm';

const title = "Admin Login | QuickBMICalculator";
const description = "Sign in to the QuickBMI administration panel.";
---

<Layout title={title} description={description} robots="noindex, nofollow">
	<Navbar client:load />

	<main class="flex-grow flex flex-col items-center justify-center py-12 sm:py-20 px-6 bg-canvas-soft">
		<div class="w-full max-w-7xl mx-auto flex flex-col items-center">
			<AuthForm client:load type="admin-login" />
		</div>
	</main>

	<Footer />
</Layout>
