---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';
import { AuthForm } from '../components/auth/AuthForm';

const title = "Admin Login | QuickBMI";
const description = "Sign in to the QuickBMI administration panel.";
---

<Layout title={title} description={description} robots="noindex, nofollow">
	<Navbar client:load />

	<main class="flex-grow flex flex-col items-center justify-center py-12 sm:py-20 px-6 bg-canvas-soft relative overflow-hidden">
		{/* Premium Background Decorations */}
		<div class="absolute inset-0 pointer-events-none -z-10 overflow-hidden">
			<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-[radial-gradient(circle,rgba(0,112,243,0.03)_0%,transparent_70%)] blur-[100px] rounded-full"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-[radial-gradient(circle,rgba(0,112,243,0.03)_0%,transparent_70%)] blur-[100px] rounded-full"></div>
			<div class="absolute top-[20%] right-[10%] w-[30%] h-[30%] bg-[radial-gradient(circle,rgba(245,166,35,0.02)_0%,transparent_70%)] blur-[80px] rounded-full"></div>
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl">
				<div class="absolute top-[-5%] left-1/2 -translate-x-1/2 w-[80%] h-[60%] bg-[radial-gradient(circle,rgba(0,112,243,0.04)_0%,transparent_70%)] blur-[120px] rounded-full"></div>
			</div>
		</div>

		<div class="w-full max-w-7xl mx-auto flex flex-col items-center relative z-10">
			<AuthForm client:load type="admin-login" />
		</div>
	</main>

	<Footer />
</Layout>
