---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';
import { AuthForm } from '../components/auth/AuthForm';

const title = "Sign Up - Join QuickBMI | QuickBMI";
const description = "Create a free QuickBMI account to start tracking your BMI, BMR, and other health metrics over time.";
---

<Layout title={title} description={description}>
	<Navbar client:load />

	<main class="flex-grow flex items-center justify-center py-24 sm:py-32 px-6 bg-canvas-soft relative overflow-hidden">
		{/* Background Decorations */}
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none -z-10">
			<div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[100%] h-[70%] bg-[radial-gradient(circle,rgba(0,223,216,0.05)_0%,transparent_70%)] blur-[100px] rounded-full"></div>
		</div>

		<div class="w-full max-w-7xl mx-auto flex flex-col items-center">
			<AuthForm client:load type="signup" />
		</div>
	</main>

	<Footer />
</Layout>
