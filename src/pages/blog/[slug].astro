---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import Footer from '../../components/Footer';
import { FAQAccordion } from '../../components/FAQAccordion';
import { ArrowRight, Clock, User, Calendar, ArrowLeft } from 'lucide-react';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);

const posts = await getCollection('blog');
const relatedPosts = posts
	.filter((p) => p.id !== post.id)
	.slice(0, 3);

// Estimate reading time
const wordCount = post.body?.split(/\s+/).length || 0;
const readingTime = Math.ceil(wordCount / 200) || 1;

const jsonLd = {
	"@type": "Article",
	"headline": post.data.title,
	"description": post.data.description,
	"image": post.data.heroImage ? new URL(post.data.heroImage, Astro.url) : new URL('/og-image.png', Astro.url),
	"author": {
		"@type": "Organization",
		"name": post.data.author
	},
	"publisher": {
		"@type": "Organization",
		"name": "QuickBMI",
		"logo": {
			"@type": "ImageObject",
			"url": new URL('/favicon-96x96.png', Astro.url)
		}
	},
	"datePublished": post.data.pubDate.toISOString(),
	"dateModified": post.data.updatedDate?.toISOString() || post.data.pubDate.toISOString()
};

const calculators = [
	{ name: 'BMI Calculator', href: '/' },
	{ name: 'BMR Calculator', href: '/bmr-calculator/' },
	{ name: 'Calorie Calculator', href: '/calorie-calculator/' },
	{ name: 'Water Intake', href: '/water-intake-calculator/' },
	{ name: 'Ideal Weight', href: '/ideal-weight-calculator/' },
];

---

<Layout 
	title={`${post.data.title} | QuickBMI Blog`} 
	description={post.data.description}
	extraSchema={[jsonLd]}
>
	<Navbar client:load />

	<main class="flex-grow pt-32 pb-20">
		<article class="max-w-3xl mx-auto px-6">
			{/* Breadcrumbs / Back Button */}
			<div class="mb-12">
				<a href="/blog/" class="inline-flex items-center gap-2 text-[11px] font-black uppercase tracking-widest text-mute hover:text-ink transition-colors group">
					<ArrowLeft className="w-3.5 h-3.5 transition-transform group-hover:-translate-x-1" />
					Back to Blog
				</a>
			</div>

			{/* Post Header */}
			<header class="mb-16">
				<div class="flex flex-wrap items-center gap-4 mb-8">
					<div class="flex items-center gap-2 px-3 py-1 rounded-full bg-primary/5 border border-primary/10">
						<Calendar className="w-3 h-3 text-primary" />
						<time datetime={post.data.pubDate.toISOString()} class="text-[10px] font-mono font-bold text-primary uppercase tracking-widest">
							{post.data.pubDate.toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'long',
								day: 'numeric',
							})}
						</time>
					</div>
					<div class="flex items-center gap-2 px-3 py-1 rounded-full bg-canvas-soft border border-hairline">
						<Clock className="w-3 h-3 text-mute" />
						<span class="text-[10px] font-mono font-bold text-mute uppercase tracking-widest">{readingTime} min read</span>
					</div>
					<div class="flex items-center gap-2 px-3 py-1 rounded-full bg-canvas-soft border border-hairline">
						<User className="w-3 h-3 text-mute" />
						<span class="text-[10px] font-mono font-bold text-mute uppercase tracking-widest">{post.data.author}</span>
					</div>
				</div>

				<h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-ink tracking-tighter mb-8 leading-[1.1]">
					{post.data.title}
				</h1>

				<p class="text-xl md:text-2xl text-mute font-medium leading-relaxed mb-12 border-l-4 border-hairline pl-8">
					{post.data.excerpt}
				</p>

				{post.data.heroImage && (
					<div class="rounded-3xl overflow-hidden shadow-premium-xl border border-hairline aspect-[16/9]">
						<img 
							src={post.data.heroImage} 
							alt={post.data.title}
							class="w-full h-full object-cover"
						/>
					</div>
				)}
			</header>

			{/* Post Content */}
			<div class="prose prose-lg prose-ink max-w-none mb-20 dark:prose-invert 
				prose-headings:tracking-tighter prose-headings:font-black prose-headings:text-ink
				prose-p:text-mute prose-p:leading-relaxed prose-p:font-medium
				prose-li:text-mute prose-li:font-medium
				prose-strong:text-ink prose-strong:font-bold
				prose-img:rounded-2xl prose-img:border prose-img:border-hairline">
				<Content />
			</div>

			{/* FAQ Section */}
			{post.data.faq && post.data.faq.length > 0 && (
				<section class="mb-20 pt-16 border-t border-hairline">
					<h2 class="text-3xl font-black text-ink tracking-tighter mb-10">Frequently Asked Questions</h2>
					<FAQAccordion 
						client:load 
						faqs={post.data.faq.map(f => ({ q: f.question, a: f.answer }))} 
					/>
				</section>
			)}

			{/* Calculators CTA - Refined Premium Dark Card */}
			<section class="mb-20 p-8 md:p-12 bg-ink text-canvas rounded-3xl relative overflow-hidden group border border-ink shadow-premium-2xl">
				<div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 blur-[120px] rounded-full translate-x-1/2 -translate-y-1/2 group-hover:bg-primary/20 transition-colors duration-1000"></div>
				<div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-500/5 blur-[100px] rounded-full -translate-x-1/2 translate-y-1/2"></div>
				
				<div class="relative z-10">
					<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-canvas/10 border border-canvas/10 mb-6">
						<div class="w-1.5 h-1.5 rounded-full bg-primary"></div>
						<span class="text-[9px] font-mono font-bold text-canvas/60 uppercase tracking-widest">Interactive Tools</span>
					</div>
					
					<h2 class="text-3xl md:text-4xl font-black tracking-tighter mb-6 leading-none">
						Take Control of Your Health
					</h2>
					<p class="text-canvas/60 text-lg mb-10 max-w-xl font-medium leading-relaxed">
						Our precision-engineered calculators provide clinical-grade insights into your body metrics. Fast, private, and free.
					</p>
					
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
						{calculators.map((calc) => (
							<a 
								href={calc.href}
								class="flex items-center justify-between px-6 py-4 bg-canvas/5 border border-canvas/10 rounded-2xl text-[11px] font-black uppercase tracking-widest hover:bg-canvas hover:text-ink transition-all group/btn shadow-sm"
							>
								{calc.name}
								<ArrowRight className="w-4 h-4 transition-transform group-hover/btn:translate-x-1" />
							</a>
						))}
					</div>
				</div>
			</section>

			{/* Related Posts */}
			{relatedPosts.length > 0 && (
				<section class="pt-16 border-t border-hairline">
					<div class="flex items-center justify-between mb-10">
						<h2 class="text-3xl font-black text-ink tracking-tighter">Related Articles</h2>
						<a href="/blog/" class="text-[11px] font-black uppercase tracking-widest text-primary hover:underline">Explore More</a>
					</div>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						{relatedPosts.map((p) => (
							<article class="group bg-canvas border border-hairline rounded-2xl overflow-hidden hover:shadow-premium-xl transition-all duration-500 flex flex-col h-full">
								{p.data.heroImage && (
									<a href={`/blog/${p.id}/`} class="aspect-[16/9] overflow-hidden border-b border-hairline">
										<img 
											src={p.data.heroImage} 
											alt={p.data.title}
											class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
										/>
									</a>
								)}
								<div class="p-6 flex flex-col flex-grow">
									<div class="flex items-center gap-3 mb-4">
										<time datetime={p.data.pubDate.toISOString()} class="text-[9px] font-mono font-bold text-mute uppercase tracking-widest">
											{p.data.pubDate.toLocaleDateString('en-US', {
												month: 'short',
												day: 'numeric',
												year: 'numeric',
											})}
										</time>
									</div>
									
									<h3 class="text-base font-bold text-ink mb-4 group-hover:text-primary transition-colors line-clamp-2 leading-tight">
										<a href={`/blog/${p.id}/`}>
											{p.data.title}
										</a>
									</h3>
									
									<div class="mt-auto">
										<a 
											href={`/blog/${p.id}/`}
											class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-ink group/link"
										>
											Read Article
											<ArrowRight className="w-3 h-3 transition-transform duration-300 group-hover/link:translate-x-1" />
										</a>
									</div>
								</div>
							</article>
						))}
					</div>
				</section>
			)}
		</article>
	</main>

	<Footer />
</Layout>

<style is:global>
	/* Custom prose styling to match the project's premium look */
	.prose h2 {
		font-size: 1.875rem;
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		letter-spacing: -0.05em;
	}
	.prose h3 {
		font-size: 1.5rem;
		margin-top: 2.5rem;
		margin-bottom: 1.25rem;
		letter-spacing: -0.025em;
	}
	.prose p {
		margin-bottom: 1.5rem;
	}
</style>
