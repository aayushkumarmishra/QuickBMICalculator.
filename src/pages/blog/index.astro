---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter(post => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Health & Wellness Blog | QuickBMI";
const description = "Explore our latest articles on health, fitness, BMI, and wellness. Stay informed with expert insights and tips.";
---

<Layout title={title} description={description}>
	<Navbar client:load />
	
	<main class="flex-grow">
		{/* HERO SECTION - Matching BMR Hero Structure Exactly */}
		<section class="relative pt-20 pb-16 sm:pt-24 sm:pb-20 lg:pb-28 px-4 sm:px-6 flex flex-col items-center bg-canvas">
			<div class="max-w-4xl mx-auto text-center space-y-4 sm:space-y-6 relative z-10">
				{/* Health Insights Badge */}
				<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/5 border border-primary/10">
					<span class="text-[10px] font-mono font-bold text-primary uppercase tracking-widest">Health Insights</span>
				</div>

				<h1 class="text-4xl sm:text-6xl lg:text-7xl font-black tracking-[-0.06em] leading-[1.05] text-ink">
					Our <span class="relative inline-block px-2 pb-2 tracking-normal bg-linear-to-r from-status-healthy to-status-under bg-clip-text text-transparent dark:bg-none dark:text-ink">
						{/* Localized Glow - Strictly behind "Blog" */}
						<div class="absolute -inset-8 sm:-inset-12 pointer-events-none -z-10">
							<div class="absolute inset-0 bg-[radial-gradient(circle,rgba(0,223,216,0.08)_0%,transparent_70%)] blur-2xl sm:blur-3xl rounded-full dark:opacity-[0.15]"></div>
							<div class="absolute inset-0 bg-[radial-gradient(circle,rgba(0,112,243,0.06)_0%,transparent_70%)] blur-3xl sm:blur-4xl rounded-full translate-y-2 dark:opacity-[0.12]"></div>
						</div>
						Blog
					</span>
				</h1>

				<p class="text-base sm:text-xl text-body max-w-2xl mx-auto leading-tight font-medium opacity-70">
					Deep dives into body metrics, health science, and wellness strategies to help you live a better life.
				</p>
			</div>
		</section>

		{/* CONTENT SECTION - Natural Flow following Hero */}
		<div class="max-w-7xl mx-auto px-6 pt-4 sm:pt-8 lg:pt-10 pb-32 relative z-10">
			{/* Blog Grid/List */}
			{posts.length > 0 ? (
				<>
					{posts.length < 3 ? (
						<div class="max-w-5xl mx-auto">
							{posts.map((post) => (
								<article class="group relative bg-canvas border border-hairline rounded-3xl overflow-hidden hover:shadow-premium-2xl transition-all duration-700 flex flex-col md:flex-row mb-12 last:mb-0 min-h-[400px]">
									{post.data.heroImage && (
										<a href={`/blog/${post.id}/`} class="md:w-1/2 aspect-[16/9] md:aspect-auto overflow-hidden border-b md:border-b-0 md:border-r border-hairline">
											<img 
												src={post.data.heroImage} 
												alt={post.data.title}
												class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
											/>
										</a>
									)}
									<div class="p-8 md:p-12 flex flex-col justify-center flex-grow md:w-1/2">
										<div class="flex items-center gap-3 mb-6">
											<time datetime={post.data.pubDate.toISOString()} class="text-[10px] font-mono font-bold text-mute uppercase tracking-widest">
												{post.data.pubDate.toLocaleDateString('en-US', {
													year: 'numeric',
													month: 'long',
													day: 'numeric',
												})}
											</time>
											<span class="w-1 h-1 rounded-full bg-hairline-strong"></span>
											<span class="text-[10px] font-mono font-bold text-primary uppercase tracking-widest">{post.data.author}</span>
										</div>
										
										<h2 class="text-3xl md:text-4xl font-black text-ink mb-6 group-hover:text-primary transition-colors tracking-tight leading-tight">
											<a href={`/blog/${post.id}/`}>
												{post.data.title}
											</a>
										</h2>
										
										<p class="text-mute text-base md:text-lg leading-relaxed mb-8 font-medium">
											{post.data.excerpt}
										</p>
										
										<div class="mt-4">
											<a 
												href={`/blog/${post.id}/`}
												class="inline-flex items-center gap-3 px-6 py-3 bg-ink text-canvas rounded-full text-[12px] font-black uppercase tracking-widest hover:bg-primary transition-colors group/link shadow-premium-lg"
											>
												Read Full Article
												<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover/link:translate-x-1">
													<path d="M5 12h14"></path>
													<path d="m12 5 7 7-7 7"></path>
												</svg>
											</a>
										</div>
									</div>
								</article>
							))}
						</div>
					) : (
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
							{posts.map((post) => (
								<article class="group bg-canvas border border-hairline rounded-2xl overflow-hidden hover:shadow-premium-xl transition-all duration-500 flex flex-col h-full">
									{post.data.heroImage && (
										<a href={`/blog/${post.id}/`} class="aspect-[16/9] overflow-hidden border-b border-hairline">
											<img 
												src={post.data.heroImage} 
												alt={post.data.title}
												class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
											/>
										</a>
									)}
									<div class="p-8 flex flex-col flex-grow">
										<div class="flex items-center gap-3 mb-4">
											<time datetime={post.data.pubDate.toISOString()} class="text-[10px] font-mono font-bold text-mute uppercase tracking-widest">
												{post.data.pubDate.toLocaleDateString('en-US', {
													year: 'numeric',
													month: 'long',
													day: 'numeric',
												})}
											</time>
											<span class="w-1 h-1 rounded-full bg-hairline-strong"></span>
											<span class="text-[10px] font-mono font-bold text-primary uppercase tracking-widest">{post.data.author}</span>
										</div>
										
										<h2 class="text-xl font-bold text-ink mb-4 group-hover:text-primary transition-colors line-clamp-2">
											<a href={`/blog/${post.id}/`}>
												{post.data.title}
											</a>
										</h2>
										
										<p class="text-mute text-sm leading-relaxed mb-8 line-clamp-3 font-medium">
											{post.data.excerpt}
										</p>
										
										<div class="mt-auto">
											<a 
												href={`/blog/${post.id}/`}
												class="inline-flex items-center gap-2 text-[11px] font-black uppercase tracking-widest text-ink group/link"
											>
												Read Article
												<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover/link:translate-x-1">
													<path d="M5 12h14"></path>
													<path d="m12 5 7 7-7 7"></path>
												</svg>
											</a>
										</div>
									</div>
								</article>
							))}
						</div>
					)}
				</>
			) : (
				<div class="bg-canvas border border-hairline rounded-2xl p-12 text-center">
					<p class="text-mute font-medium">No articles found. Check back soon!</p>
				</div>
			)}
		</div>
	</main>

	<Footer />
</Layout>

<style>
	.text-primary {
		color: #171717; /* Default to ink if no primary color defined, but usually it's a theme color */
	}
	:global(.dark) .text-primary {
		color: #fafafa;
	}
</style>
