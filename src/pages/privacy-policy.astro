---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import Footer from '../components/Footer.astro';
import HeroBackdrop from '../components/HeroBackdrop.astro';

const title = "Privacy Policy - QuickBMICalculator";
const description = "Learn how QuickBMI handles your data. We prioritize your privacy with local-first processing and zero data tracking.";
---

<Layout title={title} description={description}>
	<Navbar client:load />

	<main class="pt-32 pb-20 px-6 relative overflow-hidden">
		<HeroBackdrop />
		<article class="max-w-3xl mx-auto space-y-12">
			<header class="space-y-4">
				<h1 class="text-4xl sm:text-6xl font-black tracking-tighter text-ink leading-none">Privacy Policy</h1>
				<p class="text-mute font-mono text-xs uppercase tracking-widest">Last Updated: June 4, 2026</p>
			</header>

			<section class="prose prose-ink dark:prose-invert max-w-none space-y-8">
				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">1. Our Commitment to Privacy</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						At QuickBMICalculator, we believe that your health data is your own. Our platform is designed with a "privacy-first" architecture. We do not store, track, or share your personal health metrics on any server.
					</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">2. Local-First Processing</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						All BMI calculations, unit conversions, and health insights are performed directly in your browser. When you enter your weight or height, that data never leaves your device. This ensures total privacy and lightning-fast performance.
					</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">3. Cookies and Analytics</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						We use minimal, privacy-respecting analytics to understand site performance and improve user experience. These tools do not collect personally identifiable information (PII) or health data. We may use local storage to remember your theme preference (Light/Dark mode).
					</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">4. BMI Usage Disclaimer</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						The Body Mass Index (BMI) generated by this tool is an estimate based on standard WHO guidelines. It is intended for informational purposes only and does not constitute medical advice. Please consult with a healthcare professional for a comprehensive health assessment.
					</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">5. Data Handling</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						Because we do not collect your data, there is no data to delete or export from our systems. Your inputs are cleared as soon as you close your browser tab or refresh the page.
					</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-2xl font-black tracking-tight text-ink">6. Changes to This Policy</h2>
					<p class="text-body leading-relaxed font-medium opacity-80">
						We may update this Privacy Policy from time to time to reflect changes in our practices or for other operational, legal, or regulatory reasons.
					</p>
				</div>
			</section>
		</article>
	</main>

	<Footer />
</Layout>
