---
import Layout from '../../../layouts/Layout.astro';
import { AdminLayout } from '../../../components/admin/AdminLayout';
import { UserDetailsView } from '../../../components/admin/UserDetailsView';

export const prerender = false;

const role = Astro.locals.role;
if (!role || role !== 'admin') {
  return Astro.redirect('/403');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/users');
}

const title = "User Details | Admin | QuickBMICalculator";
const description = "View and manage registered user's health history.";
---

<Layout title={title} description={description} robots="noindex, nofollow">
  <AdminLayout currentPath="/admin/users" client:load>
    <UserDetailsView userId={id} client:load />
  </AdminLayout>
</Layout>
