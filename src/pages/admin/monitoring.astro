---
import Layout from '../../layouts/Layout.astro';
import { AdminLayout } from '../../components/admin/AdminLayout';
import { MonitoringDashboard } from '../../components/admin/MonitoringDashboard';

export const prerender = false;

const role = Astro.locals.role;
if (!role || role !== 'admin') {
  return Astro.redirect('/403');
}

const title = "System Monitoring | Admin | QuickBMICalculator";
const description = "Admin platform system monitoring dashboard.";
---

<Layout title={title} description={description} robots="noindex, nofollow">
  <AdminLayout currentPath={Astro.url.pathname} client:load>
    <MonitoringDashboard client:load />
  </AdminLayout>
</Layout>
