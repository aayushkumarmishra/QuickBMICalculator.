---
import Layout from '../../layouts/Layout.astro';
import { AdminLayout } from '../../components/admin/AdminLayout';
import { ReportManagement } from '../../components/admin/ReportManagement';

export const prerender = false;

const role = Astro.locals.role;
if (!role || role !== 'admin') {
  return Astro.redirect('/403');
}
const title = "Report Management | Admin | QuickBMICalculator";
const description = "Monitor health reports generated by users.";
---

<Layout title={title} description={description} robots="noindex, nofollow">
  <AdminLayout currentPath={Astro.url.pathname} client:load>
    <ReportManagement client:load />
  </AdminLayout>
</Layout>
