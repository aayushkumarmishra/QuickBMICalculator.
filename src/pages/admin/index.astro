---
import Layout from '../../layouts/Layout.astro';
import { AdminLayout } from '../../components/admin/AdminLayout';
import { AdminDashboard } from '../../components/admin/AdminDashboard';

export const prerender = false;

const title = "Admin Dashboard | QuickBMI";
const description = "QuickBMI Administration Panel. Monitor user growth and system health.";
---

<Layout title={title} description={description} robots="noindex, nofollow">
  <AdminLayout currentPath={Astro.url.pathname} client:load>
    <AdminDashboard client:load />
  </AdminLayout>
</Layout>
