---
import Layout from '../../layouts/Layout.astro';
import { AdminLayout } from '../../components/admin/AdminLayout';
import { AnalyticsDashboard } from '../../components/admin/AnalyticsDashboard';

export const prerender = false;

const role = Astro.locals.role;
if (!role || role !== 'admin') {
  return Astro.redirect('/403');
}
const title = "Analytics | Admin | QuickBMICalculator";
const description = "Visual growth metrics and user behavior analytics.";
---

<Layout title={title} description={description} robots="noindex, nofollow">
  <AdminLayout currentPath={Astro.url.pathname} client:load>
    <AnalyticsDashboard client:load />
  </AdminLayout>
</Layout>
